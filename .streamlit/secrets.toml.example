# Copy this file to .streamlit/secrets.toml (same folder) and fill in
# real values there. secrets.toml is gitignored - only this .example
# file (with no real secrets in it) gets committed to GitHub.

DATABASE_URL = "postgresql://user:password@host/dbname?sslmode=require"
DASHBOARD_PASSWORD = "choose-your-own-password"

# For the Daily Report's email (see daily_report.py). REPORT_EMAIL_FROM
# is the Gmail address it sends from; REPORT_EMAIL_APP_PASSWORD is a
# Google Account "App Password" (NOT your real Gmail password -
# generate one at myaccount.google.com/apppasswords, which requires
# 2-Step Verification to be turned on first). REPORT_EMAIL_RECIPIENTS
# is a comma-separated list, so more than one address can receive it.
REPORT_EMAIL_FROM = "you@gmail.com"
REPORT_EMAIL_APP_PASSWORD = "your-16-character-app-password"
REPORT_EMAIL_RECIPIENTS = "you@gmail.com, someone-else@example.com"

# For pulling trade history straight from Fidelity instead of exporting
# a CSV by hand (see snaptrade_sync.py). CLIENT_ID/CONSUMER_KEY are
# YOUR SnapTrade "Personal API Key" - create a SnapTrade account, then
# generate one from their dashboard. Never share CONSUMER_KEY; it's as
# sensitive as a password.
SNAPTRADE_CLIENT_ID = "your-snaptrade-client-id"
SNAPTRADE_CONSUMER_KEY = "your-snaptrade-consumer-key"

# USER_SECRET is different - you don't choose or generate this one
# yourself. It's created by clicking "Register with SnapTrade" on the
# Import Trades page (a one-time step), which shows it to you ONCE -
# copy it here (and into this app's Streamlit Cloud secrets, and your
# GitHub repo secrets) immediately, since SnapTrade won't show it
# again. Just as sensitive as CONSUMER_KEY above.
SNAPTRADE_USER_SECRET = "shown-once-after-you-click-register"
